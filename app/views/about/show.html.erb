<% content_for :head do %>
  <title><%= Entry::SEO.titleize("Blog") %></title>
  <%= seo_meta_tags(
    title: "Blog",
    description: "Web developer from Zagreb making products with Ruby on Rails, Hotwired and Tailwind",
    type: "website",
    url: root_url
  ) %>
<% end %>

<div class="flex flex-col gap-y-8">
  <section class="about__hero">
    <div class="about__portrait">
      <%= profile_image_tag %>
    </div>
    <div class="about__bio">
      <h1 class="txt-3xl font-bold">
        Hi, I'm Stanko Krtalic Rusendic
      </h1>
      <p>
        I am a Web developer from Zagreb making products with
        <%= link_to "Ruby on Rails", "https://rubyonrails.org/", target: :_blank %>,
        <%= link_to "Hotwired", "https://hotwired.dev/", target: :_blank %> and
        <%= link_to "Tailwind", "https://tailwindcss.com/", target: :_blank %>.
      </p>
    </div>
  </section>

  <section class="pad-inline-2">
    <div class="about__contacts">
      <%= mail_to "hey@stanko.io" do %>
        <%= about_page_contact_link_content("Email", "others_logos/hey.svg") %>
      <% end %>
      <%= link_to "https://github.com/monorkin", target: :_blank do %>
        <%= about_page_contact_link_content("GitHub", "others_logos/github.svg") %>
      <% end %>
      <%= link_to "https://mastodon.social/@monorkin", target: :_blank do %>
        <%= about_page_contact_link_content("Mastodon", "others_logos/mastodon.svg") %>
      <% end %>
      <%= link_to "https://twitter.com/monorkin", target: :_blank do %>
        <%= about_page_contact_link_content("Twitter", "others_logos/twitter.svg") %>
      <% end %>
      <%= link_to "https://www.linkedin.com/in/stanko-krtalic/", target: :_blank do %>
        <%= about_page_contact_link_content("LinkedIn", "others_logos/linkedin.png") %>
      <% end %>
    </div>
  </section>

  <section class="article flex flex-col gap-y-4">
    <h2 class="txt-2xl font-bold">
      <%= t(".latest_articles") %>
    </h2>

    <%= entry_list(@latest_entries) %>

    <div>
      <%= link_to articles_path, class: "txt-lg txt-link" do %>
        <%= text_with_icon(:arrow_long_right, t(".see_all"), position: :after) %>
      <% end %>
    </div>
  </section>
</div>
