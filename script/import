#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../config/environment"

SCHEMA_VERSION = ActiveRecord::Migrator.current_version

input_path = ARGV[0]

if input_path.nil?
  puts "Usage: ./script/import <path/to/export.json>"
  exit 1
end

unless File.exist?(input_path)
  puts "Error: File not found: #{input_path}"
  exit 1
end

puts "Importing database from #{input_path}..."

data = JSON.parse(File.read(input_path), symbolize_names: true)

if data[:schema_version] != SCHEMA_VERSION
  puts "Error: Schema version mismatch!"
  puts "  Export schema version: #{data[:schema_version]}"
  puts "  Current schema version: #{SCHEMA_VERSION}"
  puts ""
  puts "Run migrations to match schema versions before importing."
  exit 1
end

puts "Schema version: #{data[:schema_version]}"
puts "Exported at: #{data[:exported_at]}"
puts ""

conn = ActiveRecord::Base.connection

def clear_table(conn, table_name)
  conn.execute("DELETE FROM #{table_name}") if conn.table_exists?(table_name)
end

def import_table(conn, table_name, records)
  return if records.nil? || records.empty?
  return unless conn.table_exists?(table_name)

  columns = records.first.keys

  records.each do |record|
    values = columns.map do |col|
      value = record[col]
      if value.nil?
        "NULL"
      elsif value.is_a?(Integer) || value.is_a?(Float)
        value.to_s
      elsif value == true
        "1"
      elsif value == false
        "0"
      elsif value.is_a?(Hash)
        conn.quote(value.to_json)
      else
        conn.quote(value.to_s)
      end
    end

    sql = "INSERT INTO #{table_name} (#{columns.join(', ')}) VALUES (#{values.join(', ')})"
    conn.execute(sql)
  end
end

ActiveRecord::Base.transaction do
  # Clear all existing data in reverse dependency order
  puts "Clearing existing data..."
  tables_to_clear = %w[
    article_link_previews
    tag_taggings
    entries
    action_text_rich_texts
    active_storage_variant_records
    active_storage_attachments
    active_storage_blobs
    talks
    articles
    tags
    users
  ]
  tables_to_clear.each { |t| clear_table(conn, t) }
  puts "  Done"

  # Import in dependency order
  puts ""
  puts "Importing data..."

  tables_to_import = %w[
    users
    tags
    articles
    talks
    active_storage_blobs
    active_storage_attachments
    active_storage_variant_records
    action_text_rich_texts
    entries
    tag_taggings
    article_link_previews
  ]

  tables_to_import.each do |table|
    records = data[:tables][table.to_sym]
    if records.present?
      puts "  Importing #{table}..."
      import_table(conn, table, records)
      puts "    #{records.size} records"
    end
  end

  # Reset SQLite sequences
  puts ""
  puts "Resetting SQLite sequences..."
  tables_to_import.each do |table|
    next unless conn.table_exists?(table)
    max_id = conn.select_value("SELECT MAX(id) FROM #{table}") || 0
    conn.execute("UPDATE sqlite_sequence SET seq = #{max_id} WHERE name = '#{table}'")
  end
  puts "  Done"
end

puts ""
puts "Import complete!"
