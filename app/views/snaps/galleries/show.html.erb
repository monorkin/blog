<% content_for :head do %>
  <title><%= Entry::SEO.titleize(@gallery.title) %></title>
  <%= seo_meta_tags(
    title: @gallery.title,
    description: "Photo galleries and photography",
    url: gallery_url(@gallery)
  ) %>
<% end %>

<div class="photos-section">
  <div class="article margin-block-end-4">
    <div class="flex flex-row gap-x-4 items-center">
      <%= link_to "&larr;".html_safe, snaps_path, class: "txt-muted" %>
      <h1 class="txt-4xl font-semibold"><%= @gallery.title %></h1>
    </div>
  </div>

  <% if @snaps.any? %>
    <div class="photos-grid" style="view-transition-name: gallery-<%= @gallery.id %>">
      <%= render partial: "snaps/snap", collection: @snaps, as: :snap, cached: true %>
    </div>
  <% end %>
</div>
