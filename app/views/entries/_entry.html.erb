<%# locals: (entry:, entry_counter: nil, entry_iteration: nil) -%>

<%= cache entry do %>
  <% case entry.entryable %>
  <% when Article %>
    <%= render partial: "entries/article", locals: { entry: entry, article: entry.entryable } %>
  <% when Talk %>
    <%= render partial: "entries/talk", locals: { entry: entry, talk: entry.entryable } %>
  <% end %>
<% end %>
