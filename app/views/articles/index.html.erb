<% content_for :head do %>
  <title><%= Entry::SEO.titleize("Articles") %></title>
  <%= seo_meta_tags(
    title: "Articles",
    description: "Collection of articles about Ruby, Rails, and software development",
    url: articles_url
  ) %>
<% end %>

<section class="mb-4 px-2 md:px-0">
  <h1 class="text-4xl font-semibold">Articles</h1>
</section>

<% if Current.user.present? %>
  <div class="flex flex-row gap-x-4">
    <%= link_to t(".new"), new_article_path, class: primary_button_classes %>
  </div>
<% end %>

<section>
  <% if @entries.any? %>
    <%= with_automatic_pagination("articles", @page) do %>
      <%= entry_list(@entries) %>
    <% end %>
  <% else %>
    <p>No articles were found</p>
  <% end %>
</section>
