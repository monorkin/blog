<%# locals: (entry:, entry_counter: nil, entry_iteration: nil) -%>

<%= cache entry do %>
  <% case entry.entryable %>
  <% when Article %>
    <%= render partial: "articles/article", locals: { article: entry.entryable } %>
  <% when Talk %>
    <%= render partial: "talks/talk", locals: { talk: entry.entryable } %>
  <% end %>
<% end %>
