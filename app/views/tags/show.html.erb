<% content_for :head do %>
  <title><%= Entry::SEO.titleize(@tag.name) %></title>
  <%= seo_meta_tags(
    title: "##{@tag.name}",
    description: "Content tagged with #{@tag.name}",
    image: { url: asset_url("default_seo_image.jpg") },
    url: tag_url(@tag)
  ) %>
<% end %>

<section class="article margin-block-end-4">
  <h1 class="txt-4xl font-semibold">#<%= @tag.name %></h1>
  <p class="txt-subtle margin-block-start-2">
    <%= pluralize(@tag.published_entries_count, 'entry', 'entries') %> with this tag
  </p>
</section>

<% if @related_tags.any? %>
  <section class="article margin-block-end-6">
    <h2 class="txt-lg font-medium margin-block-end-2">Related Tags</h2>
    <div class="flex flex-wrap gap-2">
      <% @related_tags.each do |tag| %>
        <%= tag_bubble(tag) %>
      <% end %>
    </div>
  </section>
<% end %>

<section>
  <% if @entries.any? %>
    <%= with_automatic_pagination("tag_#{@tag.name}", @page) do %>
      <%= entry_list(@entries) %>
    <% end %>
  <% else %>
    <p class="article">No content found with this tag</p>
  <% end %>
</section>
